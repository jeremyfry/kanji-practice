# Anthropic API key (server-side only — no VITE_ prefix needed)
ANTHROPIC_API_KEY=sk-ant-...

# Server port (default: 3000)
PORT=3000

# SQLite database file path (default: kanji.db in project root)
DB_PATH=./kanji.db

# For the /import-vocab skill to reach the server:
KANJI_SERVER_URL=http://localhost:3000
